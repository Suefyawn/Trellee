# ============================================================
# Trellee — environment template
# Copy to `.env.local` and fill in. None of these should be committed.
# ============================================================

# --- Supabase ---
# From: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — server-only, never exposed to the browser.
# Used by admin server actions for privileged writes & storage.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Supabase Storage bucket names (defaults are fine, must exist in your project)
SUPABASE_STORAGE_BUCKET_MEDIA=media
SUPABASE_STORAGE_BUCKET_VIDEO=videos

# --- App ---
# Public URL of the site (used in OG tags, sitemap, emails).
# Local:       http://localhost:3000
# Production:  https://trellee.com   ← the live domain this redesign replaces.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Owner email allowed to access /admin (the single-owner admin gate).
# Must match a real user in Supabase Auth — create one in the dashboard.
# Also receives email notifications for every booking + contact submission.
ADMIN_OWNER_EMAIL=owner@trellee.com

# --- Email (Resend) ---
# Transactional emails: admin notifications + submitter confirmations for
# bookings and contact form submissions. If unset, emails fail silently
# and the form/booking still saves to the database.
#
# 1. Sign up at https://resend.com (free tier: 100/day, 3,000/mo)
# 2. Verify your sending domain (Resend → Domains → Add Domain)
# 3. Create an API key (Resend → API Keys)
RESEND_API_KEY=re_PLACEHOLDER

# "From" address — must be on a verified Resend domain. Format:
# "Display Name <address@yourdomain.com>". Anything else and Resend rejects it.
EMAIL_FROM=Trellee <hello@trellee.com>
